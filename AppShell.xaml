<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="WaveTuneNew.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:WaveTuneNew"
    Shell.NavBarIsVisible="False"
    Shell.FlyoutBehavior="Disabled"
    Title="WaveTune">
    <ShellContent
        Title="SplashPage"
        ContentTemplate="{DataTemplate local:SplashPage}"
        Route="SplashPage" />
    <ShellContent
        Title="MainPage"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="HomePage"
        ContentTemplate="{DataTemplate local:HomePage}"
        Route="HomePage" />
    <ShellContent
        Title="AlbumPage"
        ContentTemplate="{DataTemplate local:AlbumPage}"
        Route="AlbumPage" />
    <ShellContent
        Title="RegisterPage"
        ContentTemplate="{DataTemplate local:RegisterPage}"
        Route="RegisterPage" />
    <ShellContent
        Title="ProfilePage"
        ContentTemplate="{DataTemplate local:ProfilePage}"
        Route="ProfilePage" />
    <ShellContent
        Title="AboutPage"
        ContentTemplate="{DataTemplate local:AboutPage}"
        Route="AboutPage" />
    <ShellContent
        Title="GenrePage"
        ContentTemplate="{DataTemplate local:GenrePage}"
        Route="GenrePage" />
</Shell>
