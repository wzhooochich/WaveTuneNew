<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:WaveTune.ViewModels"
             x:Class="WaveTuneNew.MainPage">

    <Grid RowDefinitions="150, *, 150">
        <Grid Grid.Row="1">
            <Grid ColumnDefinitions="20*, 60*, 20*">
                <Border Grid.Column="1" StrokeShape="RoundRectangle 15">
                    <Grid ColumnDefinitions="50*, 50*">

                        <Grid Grid.Column="0">
                            <BoxView BackgroundColor="#602191" />

                            <Image Source="wtic.png"
                                   Aspect="AspectFit"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"
                                   Margin="20" />
                        </Grid>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Sign in"
                                   FontSize="24"
                                   HorizontalOptions="Center"
                                   Margin="0,20"
                                   FontAttributes="Bold" />

                            <Entry Placeholder="Login"
                                   Margin="20,15"
                                   Text="{Binding Login}" />

                            <Entry Placeholder="Password"
                                   Margin="20,15"
                                   IsPassword="True"
                                   Text="{Binding Password}" />

                            <Button Text="Continue"
                                    BackgroundColor="#602191"
                                    Margin="20,20,20,0"
                                    TextColor="#ffffff"
                                    Command="{Binding LoginCommand}" />

                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="Red"
                                   HorizontalOptions="Center" />

                            <Button Text="Don't have an account? Register now."
                                    TextColor="#ffffff"
                                    BorderWidth="0"
                                    BackgroundColor="#602191"
                                    Margin="20,0"
                                    Command="{Binding GoToRegisterPageCommand}"/>

                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>

</ContentPage>
