<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:WaveTuneNew.Views"
             x:Class="WaveTuneNew.HomePage"
             x:Name="ThisHomePage"
             Title="Home">
    <Grid RowDefinitions="100, *, Auto">

        <Grid Grid.Row="0"
              BackgroundColor="#FF1E1E1E"
              ColumnDefinitions="Auto, *, Auto, Auto"
              Padding="10,5"
              ColumnSpacing="8">

            <Border Grid.Column="0"
                    StrokeShape="RoundRectangle 20"
                    HeightRequest="40"
                    WidthRequest="40"
                    ToolTipProperties.Text="WaveTune">
                <Image Source="icon.png" Aspect="AspectFill"/>
            </Border>

            <Grid Grid.Column="1">
                <Border StrokeShape="RoundRectangle 15"
                        BackgroundColor="#FF252526"
                        Padding="15,0"
                        HeightRequest="40">
                    <Entry x:Name="SearchEntry"
                           Placeholder="Поиск треков, альбомов, авторов..."
                           PlaceholderColor="Gray"
                           TextColor="White"
                           VerticalOptions="Center"
                           Text="{Binding SearchText}"
                           ReturnCommand="{Binding GoToSearchResultsCommand}" />
                </Border>

                <Border x:Name="SuggestionsPanel"
                        BackgroundColor="#FF252526"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="1"
                        Stroke="#333333"
                        IsVisible="{Binding ShowSuggestions}"
                        VerticalOptions="Start"
                        Margin="0,44,0,0"
                        ZIndex="999">
                    <CollectionView ItemsSource="{Binding Suggestions}"
                                    x:Name="SuggestionsView">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8"
                                      ColumnDefinitions="Auto, *, Auto"
                                      ColumnSpacing="10">
                                    <Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 4"
                                            StrokeThickness="0"
                                            HeightRequest="36"
                                            WidthRequest="36">
                                        <Image Source="{Binding PictureUrl}"
                                               Aspect="AspectFill" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center"
                                                         Spacing="2">
                                        <Label Text="{Binding Name}"
                                               TextColor="White"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               MaxLines="1" />
                                        <Label Text="{Binding Author}"
                                               TextColor="#888888"
                                               FontSize="11"
                                               MaxLines="1" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="2"
                                            BackgroundColor="{Binding TypeColor}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="6,3"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding TypeLabel}"
                                               TextColor="White"
                                               FontSize="10" />
                                    </Border>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.SelectSuggestionCommand, Source={x:Reference ThisHomePage}}"
                                            CommandParameter="{Binding}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    StrokeShape="RoundRectangle 15"
                    BackgroundColor="#602191"
                    HeightRequest="40"
                    WidthRequest="40">
                <ImageButton BackgroundColor="Transparent"
                             Source="search.png"
                             HeightRequest="20"
                             WidthRequest="20"
                             Command="{Binding GoToSearchResultsCommand}"
                             ToolTipProperties.Text="Найти" />
            </Border>

            <Border Grid.Column="3"
                    StrokeShape="Ellipse"
                    HeightRequest="40"
                    WidthRequest="40"
                    BackgroundColor="#333333"
                    Stroke="#602191"
                    StrokeThickness="2"
                    ToolTipProperties.Text="Профиль">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfileTapped" />
                </Border.GestureRecognizers>
                <Grid>
                    <Label Text="W"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           IsVisible="{Binding HasNoAvatar}" />
                    <Image Source="{Binding AvatarUrl}"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasAvatar}" />
                </Grid>
            </Border>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,20">

                <Grid BackgroundColor="#FF252526" Padding="20,14">
                    <Label Text="АЛЬБОМЫ"
                           TextColor="#888888"
                           FontSize="12"
                           FontAttributes="Bold"
                           CharacterSpacing="2" />
                </Grid>

                <Grid BackgroundColor="#FF2D2D30" HeightRequest="250" Padding="10">
                    <Border BackgroundColor="#FF252526" StrokeShape="RoundRectangle 10">
                        <CollectionView ItemsSource="{Binding Albums}" Margin="10">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 5"
                                            StrokeThickness="0"
                                            WidthRequest="200">
                                        <ImageButton Source="{Binding PictureUrl}"
                                                     Aspect="AspectFill"
                                                     Command="{Binding BindingContext.GoToAlbumCommand, Source={x:Reference ThisHomePage}}"
                                                     CommandParameter="{Binding}"
                                                     ToolTipProperties.Text="Открыть альбом" />
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                </Grid>

                <Grid BackgroundColor="#FF252526" Padding="20,14">
                    <Label Text="ЖАНРЫ"
                           TextColor="#888888"
                           FontSize="12"
                           FontAttributes="Bold"
                           CharacterSpacing="2" />
                </Grid>

                <Grid BackgroundColor="#FF2D2D30" HeightRequest="250" Padding="10">
                    <Border BackgroundColor="#FF252526" StrokeShape="RoundRectangle 10">
                        <CollectionView ItemsSource="{Binding Genres}" Margin="10">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 8"
                                            StrokeThickness="0"
                                            WidthRequest="200"
                                            HeightRequest="220">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.GoToGenreCommand, Source={x:Reference ThisHomePage}}"
                                                CommandParameter="{Binding}" />
                                        </Border.GestureRecognizers>
                                        <Grid>
                                            <Image Source="{Binding PictureUrl}" Aspect="AspectFill" />
                                            <BoxView BackgroundColor="#80000000" />
                                            <Label Text="{Binding Name}"
                                                   TextColor="White"
                                                   FontSize="20"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="End"
                                                   Margin="0,0,0,12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                </Grid>

                <Button Text="О приложении"
                        BackgroundColor="Transparent"
                        TextColor="#666666"
                        FontSize="11"
                        HorizontalOptions="Center"
                        Margin="0,10,0,0"
                        Padding="10,5"
                        Clicked="OnAboutClicked"
                        ToolTipProperties.Text="Информация о приложении" />

            </VerticalStackLayout>
        </ScrollView>

        <views:PlayerBarView Grid.Row="2" />

    </Grid>
</ContentPage>
