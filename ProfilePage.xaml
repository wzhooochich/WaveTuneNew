<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WaveTuneNew.ViewModels"
             x:Class="WaveTuneNew.ProfilePage"
             Title="Профиль"
             BackgroundColor="#FF1E1E1E">

    <ContentPage.BindingContext>
        <vm:ProfileViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="60, *">

        <Grid Grid.Row="0"
              BackgroundColor="#FF1E1E1E"
              ColumnDefinitions="Auto, *"
              Padding="10,8"
              ColumnSpacing="10">

            <Button Grid.Column="0"
                    Text="←"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    FontSize="20"
                    Clicked="OnBackClicked"
                    WidthRequest="44"
                    HeightRequest="44"
                    ToolTipProperties.Text="Назад" />

            <Label Grid.Column="1"
                   Text="Профиль"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <VerticalStackLayout BackgroundColor="#FF2D2D30"
                                     Padding="24,30,24,24"
                                     Spacing="14">

                    <Grid HorizontalOptions="Center"
                          WidthRequest="116"
                          HeightRequest="116">

                        <Border StrokeShape="Ellipse"
                                Stroke="#602191"
                                StrokeThickness="3"
                                HeightRequest="116"
                                WidthRequest="116">
                            <Image Source="{Binding AvatarUrl}" Aspect="AspectFill" />
                        </Border>

                        <Border StrokeThickness="0"
                                BackgroundColor="#602191"
                                StrokeShape="Ellipse"
                                HeightRequest="32"
                                WidthRequest="32"
                                HorizontalOptions="End"
                                VerticalOptions="End"
                                ToolTipProperties.Text="Изменить фото профиля">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickAvatarCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="✎"
                                   TextColor="White"
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                    </Grid>

                    <Label Text="{Binding DisplayName}"
                           TextColor="White"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding Login, StringFormat='@{0}'}"
                           TextColor="#888888"
                           FontSize="13"
                           HorizontalOptions="Center"
                           Margin="0,-8,0,0" />

                    <BoxView HeightRequest="1" BackgroundColor="#3D3D3D" Margin="0,4" />

                    <Label Text="{Binding Bio}"
                           TextColor="#CCCCCC"
                           FontSize="14"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />

                </VerticalStackLayout>

                <Grid BackgroundColor="#FF252526" Padding="20,14">
                    <Label Text="АЛЬБОМЫ"
                           TextColor="#888888"
                           FontSize="12"
                           FontAttributes="Bold"
                           CharacterSpacing="2" />
                </Grid>

                <Grid BackgroundColor="#FF2D2D30" HeightRequest="110">
                    <Label Text="Альбомы появятся здесь"
                           TextColor="#555555"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="14" />
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#3D3D3D" />

                <Grid BackgroundColor="#FF252526" Padding="20,14">
                    <Label Text="ТРЕКИ"
                           TextColor="#888888"
                           FontSize="12"
                           FontAttributes="Bold"
                           CharacterSpacing="2" />
                </Grid>

                <Grid BackgroundColor="#FF2D2D30" HeightRequest="110">
                    <Label Text="Треки появятся здесь"
                           TextColor="#555555"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="14" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
