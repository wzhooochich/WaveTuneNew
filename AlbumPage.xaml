<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:WaveTuneNew.Views"
    x:Class="WaveTuneNew.AlbumPage"
    x:Name="AlbumPageRoot"
    BackgroundColor="#121212">

    <Grid RowDefinitions="60, *, Auto">

        <Border Grid.Row="0" BackgroundColor="#181818" StrokeThickness="0">
            <Grid ColumnDefinitions="*,*,*" Padding="20,0">
                <ImageButton Grid.Column="0"
                             Source="back.png"
                             HeightRequest="20"
                             HorizontalOptions="Start"
                             BackgroundColor="Transparent"
                             Command="{Binding GoBackCommand}"
                             ToolTipProperties.Text="Назад" />
                <Label Grid.Column="1"
                       Text="ALBUM"
                       TextColor="White"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       CharacterSpacing="2"/>
                <ImageButton Grid.Column="2"
                             Source="bell.png"
                             HeightRequest="20"
                             HorizontalOptions="End"
                             BackgroundColor="Transparent"
                             ToolTipProperties.Text="Уведомления" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto, Auto, *">

            <VerticalStackLayout Grid.Row="0" Margin="0,20" Spacing="15" HorizontalOptions="Center">
                <Border StrokeShape="RoundRectangle 15"
                        HeightRequest="220"
                        WidthRequest="220"
                        StrokeThickness="0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.5" />
                    </Border.Shadow>
                    <Image Source="{Binding CurrentAlbum.PictureUrl}" Aspect="AspectFill" />
                </Border>

                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label Text="{Binding CurrentAlbum.Title}"
                           TextColor="White"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                    <Label Text="{Binding CurrentAlbum.Author}"
                           TextColor="#B3B3B3"
                           FontSize="18"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Padding="20,8" BackgroundColor="#181818">
                <ImageButton Grid.Column="0"
                             Source="music.png"
                             HeightRequest="18"
                             Opacity="0.7"
                             ToolTipProperties.Text="Треки" />
                <ImageButton Grid.Column="1"
                             Source="eye.png"
                             HeightRequest="18"
                             Opacity="0.7"
                             ToolTipProperties.Text="Просмотры" />
                <ImageButton Grid.Column="2"
                             Source="clock.png"
                             HeightRequest="18"
                             Opacity="0.7"
                             ToolTipProperties.Text="Длительность" />
            </Grid>

            <CollectionView Grid.Row="2" ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="20,10"
                              ColumnDefinitions="Auto, *, Auto"
                              ColumnSpacing="15">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 6" StrokeThickness="0">
                                <Image Source="{Binding PictureUrl}"
                                       WidthRequest="45"
                                       HeightRequest="45"
                                       Aspect="AspectFill" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Title}"
                                       TextColor="White"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Author}"
                                       TextColor="#888888"
                                       FontSize="12" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="::"
                                   TextColor="#444444"
                                   VerticalOptions="Center"
                                   FontSize="18" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.SelectSongCommand, Source={x:Reference AlbumPageRoot}}"
                                    CommandParameter="{Binding}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <views:PlayerBarView Grid.Row="2" />

    </Grid>
</ContentPage>
