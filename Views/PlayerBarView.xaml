<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaveTuneNew.Views.PlayerBarView">

    <Border BackgroundColor="#1E1E1E"
            StrokeThickness="0"
            IsVisible="{Binding HasCurrentSong}">
        <Grid Padding="15,0"
              HeightRequest="80"
              ColumnDefinitions="1.2*, 2*, 1.2*"
              ColumnSpacing="5">

            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="12"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start">
                <Border StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        HeightRequest="55"
                        WidthRequest="55">
                    <Image Source="{Binding CurrentSong.PictureUrl}"
                           Aspect="AspectFill" />
                </Border>
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding CurrentSong.Title}"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="13"
                           MaxLines="1" />
                    <Label Text="{Binding CurrentSong.Author}"
                           TextColor="#888888"
                           FontSize="11"
                           MaxLines="1" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="End"
                                 Margin="0,0,0,12">
                <ProgressBar Progress="{Binding PlayProgress}"
                             ProgressColor="#51ADED"
                             BackgroundColor="#333333"
                             HeightRequest="4"
                             ScaleY="1.5"
                             VerticalOptions="Center" />
            </VerticalStackLayout>

            <Grid Grid.Column="2"
                  ColumnDefinitions="Auto, Auto"
                  ColumnSpacing="15"
                  HorizontalOptions="End"
                  VerticalOptions="Center">

                <HorizontalStackLayout Grid.Column="0"
                                       Spacing="5"
                                       VerticalOptions="Center">
                    <Image Source="volume_high.png"
                           HeightRequest="14"
                           Opacity="0.5" />
                    <Slider Value="{Binding Volume}"
                            WidthRequest="70"
                            MinimumTrackColor="#51ADED"
                            Scale="0.8"
                            ToolTipProperties.Text="Громкость" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1"
                                       Spacing="12"
                                       VerticalOptions="Center">
                    <ImageButton Source="previousmus.png"
                                 Command="{Binding PlayPreviousCommand}"
                                 HeightRequest="22"
                                 WidthRequest="22"
                                 ToolTipProperties.Text="Предыдущий трек" />

                    <Border StrokeShape="RoundRectangle 21"
                            HeightRequest="42"
                            WidthRequest="42"
                            BackgroundColor="White"
                            StrokeThickness="0">
                        <ImageButton Command="{Binding TogglePlayCommand}"
                                     HeightRequest="18"
                                     WidthRequest="18"
                                     Aspect="AspectFit"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     BackgroundColor="Transparent"
                                     Padding="0"
                                     ToolTipProperties.Text="Играть / Пауза">
                            <ImageButton.Triggers>
                                <DataTrigger TargetType="ImageButton"
                                             Binding="{Binding IsPlaying}"
                                             Value="True">
                                    <Setter Property="Source" Value="stop.png" />
                                </DataTrigger>
                                <DataTrigger TargetType="ImageButton"
                                             Binding="{Binding IsPlaying}"
                                             Value="False">
                                    <Setter Property="Source" Value="play.png" />
                                </DataTrigger>
                            </ImageButton.Triggers>
                        </ImageButton>
                    </Border>

                    <ImageButton Source="nextmus.png"
                                 Command="{Binding PlayNextCommand}"
                                 HeightRequest="22"
                                 WidthRequest="22"
                                 ToolTipProperties.Text="Следующий трек" />
                </HorizontalStackLayout>
            </Grid>

        </Grid>
    </Border>
</ContentView>
