<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaveTuneNew.Views.PlayerBarView">

    <Border BackgroundColor="#181818"
            StrokeThickness="0"
            IsVisible="{Binding HasCurrentSong}">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,-4" Radius="12" Opacity="0.6" />
        </Border.Shadow>
        <Grid HeightRequest="80"
              Padding="16,0"
              ColumnDefinitions="*, Auto, *">

            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="12"
                                   VerticalOptions="Center">
                <Border StrokeShape="RoundRectangle 4"
                        StrokeThickness="0"
                        HeightRequest="52"
                        WidthRequest="52">
                    <Image Source="{Binding CurrentSong.PictureUrl}"
                           Aspect="AspectFill" />
                </Border>
                <VerticalStackLayout VerticalOptions="Center" Spacing="3">
                    <Label Text="{Binding CurrentSong.Title}"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="13"
                           MaxLines="1" />
                    <Label Text="{Binding CurrentSong.Author}"
                           TextColor="#B3B3B3"
                           FontSize="11"
                           MaxLines="1" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8">
                <HorizontalStackLayout Spacing="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center">
                    <ImageButton Source="previousmus.png"
                                 Command="{Binding PlayPreviousCommand}"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 BackgroundColor="Transparent"
                                 ToolTipProperties.Text="Предыдущий" />

                    <Border StrokeShape="Ellipse"
                            HeightRequest="40"
                            WidthRequest="40"
                            BackgroundColor="White"
                            StrokeThickness="0">
                        <ImageButton Command="{Binding TogglePlayCommand}"
                                     HeightRequest="24"
                                     WidthRequest="24"
                                     Aspect="AspectFit"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     BackgroundColor="Transparent"
                                     Padding="0"
                                     ToolTipProperties.Text="Играть / Пауза">
                            <ImageButton.Triggers>
                                <DataTrigger TargetType="ImageButton"
                                             Binding="{Binding IsPlaying}"
                                             Value="True">
                                    <Setter Property="Source" Value="stop.png" />
                                </DataTrigger>
                                <DataTrigger TargetType="ImageButton"
                                             Binding="{Binding IsPlaying}"
                                             Value="False">
                                    <Setter Property="Source" Value="play.png" />
                                </DataTrigger>
                            </ImageButton.Triggers>
                        </ImageButton>
                    </Border>

                    <ImageButton Source="nextmus.png"
                                 Command="{Binding PlayNextCommand}"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 BackgroundColor="Transparent"
                                 ToolTipProperties.Text="Следующий" />
                </HorizontalStackLayout>

                <ProgressBar Progress="{Binding PlayProgress}"
                             ProgressColor="White"
                             BackgroundColor="#535353"
                             HeightRequest="3"
                             WidthRequest="300"
                             VerticalOptions="Center" />
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="2"
                                   Spacing="8"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center">
                <Grid ColumnDefinitions="Auto, Auto"
                      ColumnSpacing="6"
                      VerticalOptions="Center">
                    <Grid.GestureRecognizers>
                        <PointerGestureRecognizer
                            PointerEnteredCommand="{Binding ShowVolumeCommand}"
                            PointerExitedCommand="{Binding HideVolumeCommand}" />
                    </Grid.GestureRecognizers>
                    <Image Grid.Column="0"
                           Source="volume_high.png"
                           HeightRequest="18"
                           WidthRequest="18"
                           Opacity="0.7" />
                    <Slider Grid.Column="1"
                            Value="{Binding Volume}"
                            WidthRequest="90"
                            MinimumTrackColor="White"
                            MaximumTrackColor="#535353"
                            ThumbColor="White"
                            IsVisible="{Binding IsVolumeVisible}"
                            ToolTipProperties.Text="Громкость" />
                </Grid>
            </HorizontalStackLayout>

        </Grid>
    </Border>
</ContentView>
